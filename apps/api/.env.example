# Postgres connection string (same as packages/db)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Supabase project (used to verify JWTs when an Authorization header is present)
SUPABASE_URL=https://veovkdadpdwkoqliiyiv.supabase.co/
SUPABASE_SERVICE_ROLE_KEY=REDACTED
# JWT secret from Supabase: Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

PORT=3001
NODE_ENV=development

# Dev auth bypass (spec §12): used as req.userId when no Authorization header is sent.
DEV_USER_ID=00000000-0000-0000-0000-000000000000
