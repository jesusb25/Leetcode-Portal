# Local dev default. In production this points at the deployed API:
# https://leetcode-api-9kz7.onrender.com/api/v1 (set in render.yaml).
# Required for production builds — `vite build` fails if this is unset
# (otherwise the app silently falls back to the localhost URL below).
VITE_API_URL=http://localhost:3001/api/v1
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
