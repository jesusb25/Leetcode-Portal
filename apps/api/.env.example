# Postgres connection string (same as packages/db).
# Runtime/API can use Supabase's transaction pooler:
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# For migrations/DDL, use Supabase's direct connection instead:
# DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase project (used to verify JWTs when an Authorization header is present).
# Find these at: Supabase → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

PORT=3001
NODE_ENV=development

# Dev auth bypass (spec §12): used as req.userId when no Authorization header is sent.
DEV_USER_ID=00000000-0000-0000-0000-000000000000
