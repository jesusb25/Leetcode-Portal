{
  "name": "leetcode-srs",
  "private": true,
  "version": "0.1.0",
  "description": "LeetCode spaced repetition system (MVP)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:rls": "pnpm --filter @repo/db db:rls",
    "db:seed": "pnpm --filter @repo/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
